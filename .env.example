# Copy to .env.local for local dev — set these in Vercel dashboard for production

# Vercel KV (auto-filled when you connect KV database in Vercel dashboard)
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Solana wallet address to track for incoming fees
WATCHED_WALLET=

# Secret for the /api/reset endpoint (you pick this password)
ADMIN_SECRET=
